# =============================================================
# FRONTEND — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# All variables must be prefixed with VITE_ to be exposed in the browser.
# NEVER put secrets here — this is public client-side code.
# =============================================================

# ── API ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api     # Production: https://your-api.fly.dev/api

# ── Store Branding ────────────────────────────────────────────
VITE_STORE_NAME=Mi Tienda Online
VITE_LOGO_URL=/logo.png

# ── Social Media ─────────────────────────────────────────────
VITE_WHATSAPP_NUMBER=5491100000000         # Format: country code + number, no spaces
VITE_INSTAGRAM_URL=https://instagram.com/tutienda
VITE_TIKTOK_URL=https://www.tiktok.com/@tutienda

# ── Contact ──────────────────────────────────────────────────
VITE_CONTACT_EMAIL=contacto@tutienda.com
VITE_CONTACT_PHONE=+54 11 0000-0000

# ── Store Locations ──────────────────────────────────────────
VITE_SUCURSAL_1_NOMBRE=Sucursal 1
VITE_SUCURSAL_1_DIRECCION=Calle Principal 123
VITE_SUCURSAL_1_DETALLES=Local 1

VITE_SUCURSAL_2_NOMBRE=Sucursal 2
VITE_SUCURSAL_2_DIRECCION=Avenida Secundaria 456
VITE_SUCURSAL_2_DETALLES=Local 2

